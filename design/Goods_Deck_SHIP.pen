d": "QejOe", "name": "l", "fill": "$muted", "content": "HDPE DIVERTED", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "frame", "id": "MMShE", "name": "Voice", "width": "fill_container", "stroke": "$terra", "strokeWidth": {"left": 2}, "strokeAlignment": "inner", "layout": "vertical", "gap": 5, "padding": [0, 0, 0, 18], "children": [{"type": "text", "id": "F2aT7", "name": "Quote", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "Our bed is right. That's good. Good.", "fontFamily": "$font-body", "fontSize": 15, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "JzX3F", "name": "Attrib", "fill": "$muted", "content": "MARGARET LLOYD · UTOPIA HOMELANDS, ~30 YEARS ON HER HOMELAND", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "frame", "id": "f5bi6q", "x": 0, "y": 840, "name": "FINAL2 05 — Waste plastic in, a bed out", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "layout": "vertical", "gap": 20, "padding": [56, 72], "children": [{"type": "frame", "id": "q2KmSE", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-black.png", "mode": "fit"}}, {"type": "frame", "id": "Ha9G1", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "w8uRa", "name": "Folio", "fill": "$terra", "content": "05", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "Tmnz9", "name": "Door", "fill": "$terra", "content": "see it live → goodsoncountry.com/atlas", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 1.4}]}, {"type": "rectangle", "id": "HOVUt", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "HTkwz", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Waste plastic in. A bed out. On Country.", "lineHeight": 1.15, "fontFamily": "$font-display", "fontSize": 40, "fontWeight": "normal"}, {"type": "text", "id": "JlDfB", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "20kg of plastic a bed. 3,540kg diverted so far. We buy the plastic today; collecting it on Country is the next move.", "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "sp8hM", "name": "Drawing", "width": "fill_container", "height": 328, "fill": {"type": "image", "enabled": true, "url": "../generated-images/goods-illustrations/transparent/02-loop-on-country-on-light.png", "mode": "fit"}}, {"type": "frame", "id": "sMQw2", "name": "Voice", "width": "fill_container", "stroke": "$terra", "strokeWidth": {"left": 2}, "strokeAlignment": "inner", "layout": "vertical", "gap": 5, "padding": [0, 0, 0, 18], "children": [{"type": "text", "id": "uP3Ca", "name": "Quote", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "They're definitely not gonna break, I can tell you that ... the recycled plastic that you use from that is blowing my mind away ... Every sheet was a different design.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 15, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "F4sr1N", "name": "Attrib", "fill": "$muted", "content": "SHAYNE BLOOMFIELD · OONCHIUMPA · ALICE SPRINGS", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "frame", "id": "Y2n9TY", "x": 1400, "y": 840, "name": "FINAL2 06 — We pressed their beds ourselves", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "children": [{"type": "frame", "id": "PSMBs", "name": "Photo panel", "width": 512, "height": 720, "fill": {"type": "image", "enabled": true, "url": "../v2/public/images/process/heat-press-full.jpg", "mode": "fill"}}, {"type": "frame", "id": "C6njKI", "name": "Text panel", "width": "fill_container", "height": 720, "layout": "vertical", "gap": 22, "padding": [56, 60], "justifyContent": "center", "children": [{"type": "frame", "id": "YRSqi", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "Csbdm", "name": "Folio", "fill": "$terra", "content": "06", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}]}, {"type": "rectangle", "id": "qs72q", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "NKDy8", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Maningrida ordered more. We pressed their beds ourselves.", "lineHeight": 1.15, "fontFamily": "$font-display", "fontSize": 38, "fontWeight": "normal"}, {"type": "text", "id": "FqxOQ", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "All 40 Stretch Beds on invoice INV-0303. Legs pressed at 180°C at our own facility, then built in community under the mango trees. The press works. The next run gets the stopwatch.", "lineHeight": 1.5, "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "ge4oc", "name": "Voice", "width": "fill_container", "stroke": "$terra", "strokeWidth": {"left": 2}, "strokeAlignment": "inner", "layout": "vertical", "gap": 5, "padding": [0, 0, 0, 18], "children": [{"type": "text", "id": "aV0H9", "name": "Quote", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "We made 20 odd beds in aged care ... utilizing the young people of the aged care service ... They were so willing to learn about how these beds came together.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 15, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "NomYP", "name": "Attrib", "fill": "$muted", "content": "SHAYNE BLOOMFIELD · OONCHIUMPA", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}]}]}]}, {"type": "frame", "id": "xg24u", "x": 2800, "y": 840, "name": "FINAL2 07 — Built by the people who sleep on them", "clip": true, "width": 1280, "height": 720, "fill": {"type": "image", "enabled": true, "url": "deck-photos/maningrida-trip/maningrida-trip-06.jpg", "mode": "fill"}, "layout": "none", "children": [{"type": "rectangle", "id": "mog67", "x": 0, "y": 180, "name": "Scrim", "fill": {"type": "gradient", "gradientType": "linear", "enabled": true, "rotation": 180, "size": {"height": 1}, "colors": [{"color": "#0A0A0A00", "position": 0}, {"color": "#0A0A0AB8", "position": 0.45}, {"color": "#0A0A0AFA", "position": 1}]}, "width": 1280, "height": 540}, {"type": "frame", "id": "t6sFe", "layoutPosition": "absolute", "x": 72, "y": 398, "name": "Content", "width": 1040, "layout": "vertical", "gap": 20, "children": [{"type": "text", "id": "V7PW6x", "name": "Folio", "fill": "$terra-lite", "content": "07", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "mnOX2", "name": "Line", "fill": "$cream", "textGrowth": "fixed-width", "width": 920, "content": "Built by the people who sleep on them.", "lineHeight": 1.15, "fontFamily": "$font-display", "fontSize": 46, "fontWeight": "normal"}, {"type": "frame", "id": "NG8DZ", "name": "Voice", "width": 800, "stroke": "$terra", "strokeWidth": {"left": 2}, "strokeAlignment": "inner", "layout": "vertical", "gap": 6, "padding": [14, 0, 0, 18], "children": [{"type": "text", "id": "X4GZC", "name": "Quote", "fill": "#EDE6DA", "textGrowth": "fixed-width", "width": "fill_container", "content": "Yeah, I'll be rocking up every day to make them.", "lineHeight": 1.5, "fontFamily": "$font-body", "fontSize": 17, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "zBEFQ", "name": "Attrib", "fill": "$muted-on-ink", "content": "MYKEL · YOUNG MAKER · UTOPIA", "fontFamily": "$font-mono", "fontSize": 12, "fontWeight": "normal", "letterSpacing": 1}]}]}, {"type": "frame", "id": "nP3N9", "layoutPosition": "absolute", "x": 56, "y": 44, "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-white.png", "mode": "fit"}}]}, {"type": "frame", "id": "zERSX", "x": 4200, "y": 840, "name": "FINAL2 08 — Watch where each $750 goes", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "layout": "vertical", "gap": 20, "padding": [56, 72], "children": [{"type": "frame", "id": "YQ1fe", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-black.png", "mode": "fit"}}, {"type": "frame", "id": "gnKXS", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "CFVYF", "name": "Folio", "fill": "$terra", "content": "08", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "HvUoX", "name": "Door", "fill": "$terra", "content": "see it live → goodsoncountry.com/investors", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 1.4}]}, {"type": "rectangle", "id": "sbdmj", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "FcwdE", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Watch where each $750 goes.", "lineHeight": 1.12, "fontFamily": "$font-display", "fontSize": 42, "fontWeight": "normal"}, {"type": "text", "id": "Pn08E", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "A Stretch Bed sells for $750. What is left after the bed is made is what pays the yearly bill.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "EwPZ1", "name": "TODAY · LEGS BOUGHT AS KITS", "width": "fill_container", "layout": "vertical", "gap": 8, "padding": [10, 0, 0, 0], "children": [{"type": "frame", "id": "S7HA0c", "name": "lab", "width": "fill_container", "gap": 10, "alignItems": "center", "children": [{"type": "text", "id": "E2vnW", "name": "l", "fill": "$ink", "content": "TODAY · LEGS BOUGHT AS KITS", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}, {"type": "frame", "id": "fQqHl", "name": "chip VERIFIED", "cornerRadius": 2, "stroke": "$sage", "strokeWidth": 1, "strokeAlignment": "inner", "padding": [4, 9], "children": [{"type": "text", "id": "XSLr7", "name": "t", "fill": "$sage", "content": "VERIFIED", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "frame", "id": "y0as9c", "name": "bar", "width": "fill_container", "height": 46, "gap": 3, "children": [{"type": "rectangle", "cornerRadius": [3, 0, 0, 3], "id": "aUdly", "name": "cost", "fill": "$muted", "width": 1038, "height": 46, "stroke": "$ink-2", "strokeWidth": 1, "strokeAlignment": "inner"}, {"type": "rectangle", "cornerRadius": [0, 3, 3, 0], "id": "sLCIs", "name": "stays", "fill": "$sage", "width": 95, "height": 46}]}, {"type": "frame", "id": "scAvE", "name": "under", "width": "fill_container", "gap": 3, "children": [{"type": "text", "id": "TP8CM", "name": "c", "fill": "$ink-2", "textGrowth": "fixed-width", "width": 1038, "content": "$685 to make the bed", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal"}, {"type": "text", "id": "F1nBw2", "name": "s", "fill": "$sage", "textGrowth": "fixed-width", "width": 95, "content": "$65", "fontFamily": "$font-display", "fontSize": 20, "fontWeight": "normal"}]}]}, {"type": "frame", "id": "r8p7n6", "name": "PRESSING OUR OWN LEGS", "width": "fill_container", "layout": "vertical", "gap": 8, "padding": [10, 0, 0, 0], "children": [{"type": "frame", "id": "IuGcv", "name": "lab", "width": "fill_container", "gap": 10, "alignItems": "center", "children": [{"type": "text", "id": "iizgp", "name": "l", "fill": "$ink", "content": "PRESSING OUR OWN LEGS", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}, {"type": "frame", "id": "dgjNH", "name": "chip MODELLED", "cornerRadius": 2, "stroke": "$terra", "strokeWidth": 1, "strokeAlignment": "inner", "padding": [4, 9], "children": [{"type": "text", "id": "w4j3bM", "name": "t", "fill": "$terra", "content": "MODELLED", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "frame", "id": "cUmrI", "name": "bar", "width": "fill_container", "height": 46, "gap": 3, "children": [{"type": "rectangle", "cornerRadius": [3, 0, 0, 3], "id": "SxQiQ", "name": "cost", "fill": "$muted", "width": 645, "height": 46, "stroke": "$ink-2", "strokeWidth": 1, "strokeAlignment": "inner"}, {"type": "rectangle", "cornerRadius": [0, 3, 3, 0], "id": "sg0Se", "name": "stays", "fill": "$sage", "width": 488, "height": 46}]}, {"type": "frame", "id": "T17wqQ", "name": "under", "width": "fill_container", "gap": 3, "children": [{"type": "text", "id": "ryZQt", "name": "c", "fill": "$ink-2", "textGrowth": "fixed-width", "width": 645, "content": "$426 to make the bed", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal"}, {"type": "text", "id": "Y0MVvE", "name": "s", "fill": "$sage", "textGrowth": "fixed-width", "width": 488, "content": "$324", "fontFamily": "$font-display", "fontSize": 20, "fontWeight": "normal"}]}]}, {"type": "text", "id": "vHOTO", "name": "Note", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "Modelled from verified part prices. The first thing this raise buys is the measured 50-bed run that proves it. The yearly bill is about $109,500, so break-even is roughly 338 beds a year. We are at about 120.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 14, "fontWeight": "normal"}]}, {"type": "frame", "id": "TiYBr", "x": 0, "y": 1680, "name": "FINAL2 09 — $400K signed by 31 August", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "layout": "vertical", "gap": 20, "padding": [56, 72], "children": [{"type": "frame", "id": "fNDFk", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-black.png", "mode": "fit"}}, {"type": "frame", "id": "EEEF3", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "xOwbA", "name": "Folio", "fill": "$terra", "content": "09", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "qGc9V", "name": "Door", "fill": "$terra", "content": "see it live → goodsoncountry.com/investors", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 1.4}]}, {"type": "rectangle", "id": "K2wOVF", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "h4fBq8", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "$400K signed by 31 August. QBE doubles it.", "lineHeight": 1.12, "fontFamily": "$font-display", "fontSize": 42, "fontWeight": "normal"}, {"type": "text", "id": "A0iTEg", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "QBE matches signed external commitments dollar for dollar. Submission 14 September. Signed today: $0.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "zGoas", "name": "Stack", "width": "fill_container", "layout": "vertical", "gap": 10, "padding": [8, 0, 0, 0], "children": [{"type": "frame", "id": "A4HS1", "name": "SEFA · REPAYABLE", "width": "fill_container", "gap": 14, "alignItems": "center", "children": [{"type": "text", "id": "B6oFwd", "name": "l", "fill": "$ink", "textGrowth": "fixed-width", "width": 250, "content": "SEFA · REPAYABLE", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1}, {"type": "rectangle", "cornerRadius": 2, "id": "jwXlb", "name": "b", "fill": "$terra", "width": 426, "height": 30}, {"type": "text", "id": "PFeiO", "name": "v", "fill": "$ink", "content": "$300K", "fontFamily": "$font-display", "fontSize": 19, "fontWeight": "normal"}, {"type": "text", "id": "E8yQOq", "name": "s", "fill": "$muted", "content": "TARGET · $0 SIGNED", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1}]}, {"type": "frame", "id": "ERslZ", "name": "SNOW FOUNDATION · GRANT", "width": "fill_container", "gap": 14, "alignItems": "center", "children": [{"type": "text", "id": "aUdJi", "name": "l", "fill": "$ink", "textGrowth": "fixed-width", "width": 250, "content": "SNOW FOUNDATION · GRANT", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1}, {"type": "rectangle", "cornerRadius": 2, "id": "e2ng5", "name": "b", "fill": "$terra-lite", "width": 142, "height": 30}, {"type": "text", "id": "d2uMl", "name": "v", "fill": "$ink", "content": "$100K", "fontFamily": "$font-display", "fontSize": 19, "fontWeight": "normal"}, {"type": "text", "id": "woUq5", "name": "s", "fill": "$muted", "content": "TARGET · $0 SIGNED", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1}]}, {"type": "frame", "id": "AMkNC", "name": "CENTRECORP · GRANT", "width": "fill_container", "gap": 14, "alignItems": "center", "children": [{"type": "text", "id": "MMve9", "name": "l", "fill": "$ink", "textGrowth": "fixed-width", "width": 250, "content": "CENTRECORP · GRANT", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1}, {"type": "rectangle", "cornerRadius": 2, "id": "XB5UW", "name": "b", "fill": "$terra-lite", "width": 106, "height": 30}, {"type": "text", "id": "Y9wCcF", "name": "v", "fill": "$ink", "content": "$75K", "fontFamily": "$font-display", "fontSize": 19, "fontWeight": "normal"}, {"type": "text", "id": "DDeiW", "name": "s", "fill": "$muted", "content": "TARGET · $0 SIGNED", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1}]}, {"type": "frame", "id": "Bo18q", "name": "QBE MATCH", "width": "fill_container", "gap": 14, "alignItems": "center", "children": [{"type": "text", "id": "f7lg0", "name": "l", "fill": "$ink", "textGrowth": "fixed-width", "width": 250, "content": "QBE MATCH", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1}, {"type": "rectangle", "cornerRadius": 2, "id": "i0BfW", "name": "b", "fill": "$sage", "width": 568, "height": 30}, {"type": "text", "id": "Iux1o", "name": "v", "fill": "$ink", "content": "$400K", "fontFamily": "$font-display", "fontSize": 19, "fontWeight": "normal"}, {"type": "text", "id": "x2iLY", "name": "s", "fill": "$muted", "content": "UNLOCKED BY SIGNED PAPER", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1}]}]}, {"type": "text", "id": "QZRzy", "name": "Total", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "$475K target stack, with headroom over the $400K. Matched, that is an $800K program that takes Goods to the point it funds itself.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 15, "fontWeight": "normal"}]}, {"type": "frame", "id": "yC11a", "x": 1400, "y": 1680, "name": "FINAL2 10 — Nobody funds Goods forever", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "layout": "vertical", "gap": 20, "padding": [56, 72], "children": [{"type": "frame", "id": "y2yXf", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-black.png", "mode": "fit"}}, {"type": "frame", "id": "XYFkn", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "wB82U", "name": "Folio", "fill": "$terra", "content": "10", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "c164wd", "name": "Door", "fill": "$terra", "content": "see it live → goodsoncountry.com/investors", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 1.4}]}, {"type": "rectangle", "id": "tTbfI", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "sfqT1", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Nobody funds Goods forever. That is the design.", "lineHeight": 1.12, "fontFamily": "$font-display", "fontSize": 42, "fontWeight": "normal"}, {"type": "text", "id": "Y9Reb", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "Trading result before grants, from the three-statement model. Gifts end at break-even, loans go home, sales carry it. Then it changes owner.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "UdmPD", "name": "Scaffold drawing", "width": "fill_container", "height": 300, "fill": {"type": "image", "enabled": true, "url": "../generated-images/goods-illustrations/transparent/05-taper-scaffold-on-light.png", "mode": "fit"}}, {"type": "frame", "id": "m2VpHF", "name": "Figures", "width": "fill_container", "gap": 28, "padding": [6, 0, 0, 0], "children": [{"type": "frame", "id": "fJr95", "name": "FY27 · TRADING BEFORE GRANTS", "width": "fill_container", "stroke": "$ink", "strokeWidth": {"top": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 3, "padding": [10, 0, 0, 0], "children": [{"type": "text", "id": "di63o", "name": "v", "fill": "$terra", "content": "-$229K", "fontFamily": "$font-display", "fontSize": 22, "fontWeight": "normal"}, {"type": "text", "id": "E5RY3", "name": "l", "fill": "$muted", "textGrowth": "fixed-width", "width": "fill_container", "content": "FY27 · TRADING BEFORE GRANTS", "fontFamily": "$font-mono", "fontSize": 9.5, "fontWeight": "normal", "letterSpacing": 1}]}, {"type": "frame", "id": "F4ycpv", "name": "FY28 · THE CROSSING, 338 BEDS", "width": "fill_container", "stroke": "$ink", "strokeWidth": {"top": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 3, "padding": [10, 0, 0, 0], "children": [{"type": "text", "id": "nlu88", "name": "v", "fill": "$ink-2", "content": "break-even", "fontFamily": "$font-display", "fontSize": 22, "fontWeight": "normal"}, {"type": "text", "id": "BjnCT", "name": "l", "fill": "$muted", "textGrowth": "fixed-width", "width": "fill_container", "content": "FY28 · THE CROSSING, 338 BEDS", "fontFamily": "$font-mono", "fontSize": 9.5, "fontWeight": "normal", "letterSpacing": 1}]}, {"type": "frame", "id": "RP0AE", "name": "FY29 · GRANT-FREE, STANDS ALONE", "width": "fill_container", "stroke": "$ink", "strokeWidth": {"top": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 3, "padding": [10, 0, 0, 0], "children": [{"type": "text", "id": "F3eUBa", "name": "v", "fill": "$sage", "content": "+$10K", "fontFamily": "$font-display", "fontSize": 22, "fontWeight": "normal"}, {"type": "text", "id": "g6id9k", "name": "l", "fill": "$muted", "textGrowth": "fixed-width", "width": "fill_container", "content": "FY29 · GRANT-FREE, STANDS ALONE", "fontFamily": "$font-mono", "fontSize": 9.5, "fontWeight": "normal", "letterSpacing": 1}]}]}, {"type": "text", "id": "CibKT", "name": "Chip", "fill": "$muted", "content": "MODELLED  ·  SOURCE: GOC 3-STATEMENT MODEL v1", "fontFamily": "$font-mono", "fontSize": 9.5, "fontWeight": "normal", "letterSpacing": 1.3}]}, {"type": "frame", "id": "Uhxzs", "x": 2800, "y": 1680, "name": "FINAL2 11 — The plant moves into community hands", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "layout": "vertical", "gap": 20, "padding": [56, 72], "children": [{"type": "frame", "id": "lVLQN", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-black.png", "mode": "fit"}}, {"type": "frame", "id": "OADJH", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "kLUpF", "name": "Folio", "fill": "$terra", "content": "11", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "OYRUY", "name": "Door", "fill": "$terra", "content": "see it live → goodsoncountry.com/investors", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 1.4}]}, {"type": "rectangle", "id": "q5Xeic", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "DBpGA", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "The plant moves into community hands.", "lineHeight": 1.15, "fontFamily": "$font-display", "fontSize": 40, "fontWeight": "normal"}, {"type": "text", "id": "Jvst3", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "Four communities are already asking: Palm Island, Alice Springs, Utopia, Tennant Creek. What a site needs to pay its own way is being rebuilt from the real facility budget.", "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "fl3Gp", "name": "Drawing", "width": "fill_container", "height": 328, "fill": {"type": "image", "enabled": true, "url": "../generated-images/goods-illustrations/transparent/04-handover-gates-on-light.png", "mode": "fit"}}, {"type": "frame", "id": "j1M9t", "name": "Voice", "width": "fill_container", "stroke": "$terra", "strokeWidth": {"left": 2}, "strokeAlignment": "inner", "layout": "vertical", "gap": 5, "padding": [0, 0, 0, 18], "children": [{"type": "text", "id": "y4jXWu", "name": "Quote", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "If we have our own contract doing all these in the communities, they can sell 'em to people... and even to Tennant Creek come where we have NAIDOC week or we have show... marquees sort of sell 'em.", "lineHeight": 1.45, "fontFamily": "$font-body", "fontSize": 15, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "MNY7b", "name": "Attrib", "fill": "$muted", "content": "DIANNE STOKES · WARUMUNGU AND WARLMANPA ELDER · TENNANT CREEK", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "frame", "id": "ke4cF", "x": 4200, "y": 1680, "name": "FINAL2 12 — Come back home", "clip": true, "width": 1280, "height": 720, "fill": {"type": "image", "enabled": true, "url": "deck-photos/storyteller-dianne-stokes.jpg", "mode": "fill"}, "layout": "none", "children": [{"type": "rectangle", "id": "d7FZQ", "x": 0, "y": 120, "name": "Scrim", "fill": {"type": "gradient", "gradientType": "linear", "enabled": true, "rotation": 180, "size": {"height": 1}, "colors": [{"color": "#0A0A0A00", "position": 0}, {"color": "#0A0A0AC4", "position": 0.4}, {"color": "#0A0A0AFC", "position": 1}]}, "width": 1280, "height": 600}, {"type": "frame", "id": "erNpm", "layoutPosition": "absolute", "x": 72, "y": 344, "name": "Content", "width": 1040, "layout": "vertical", "gap": 22, "children": [{"type": "text", "id": "a2KqC", "name": "Folio", "fill": "$terra-lite", "content": "12", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "npOCk", "name": "Quote", "fill": "$cream", "textGrowth": "fixed-width", "width": 1000, "content": "“It means something that really makes me happy. Every time I go away, it's like it's calling me. Come back home.”", "lineHeight": 1.2, "fontFamily": "$font-display", "fontSize": 42, "fontWeight": "normal"}, {"type": "text", "id": "S4gJvb", "name": "Attrib", "fill": "$muted-on-ink", "content": "DIANNE STOKES  ·  WARUMUNGU AND WARLMANPA ELDER  ·  TENNANT CREEK", "fontFamily": "$font-mono", "fontSize": 12, "fontWeight": "normal", "letterSpacing": 1.6}, {"type": "text", "id": "N5t0zk", "name": "Sub", "fill": "#C9C2B6", "textGrowth": "fixed-width", "width": 900, "content": "She designed and named both products. Pakkimjalki Kari is her name for the washing machine.", "fontFamily": "$font-body", "fontSize": 15, "fontWeight": "normal"}]}, {"type": "frame", "id": "yEuu5", "layoutPosition": "absolute", "x": 56, "y": 44, "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-white.png", "mode": "fit"}}]}, {"type": "frame", "id": "HcXFS", "x": 0, "y": 2520, "name": "APPENDIX A — the three hands (entity structure)", "clip": true, "width": 1280, "height": 720, "fill": "$ink", "layout": "vertical", "padding": [44, 56], "children": [{"type": "frame", "id": "YTqy9", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-white.png", "mode": "fit"}}, {"type": "frame", "id": "EJ5Bt", "name": "Body", "width": "fill_container", "height": "fill_container", "layout": "vertical", "gap": 18, "justifyContent": "center", "children": [{"type": "rectangle", "id": "Mpp69", "name": "Rule", "fill": "$terra", "width": 34, "height": 2}, {"type": "text", "id": "hvK63", "name": "Line", "fill": "$cream", "textGrowth": "fixed-width", "width": 820, "content": "Three names. One work.", "lineHeight": 1.2, "fontFamily": "$font-display", "fontSize": 34, "fontWeight": "normal"}, {"type": "frame", "id": "nTbXW", "name": "Columns", "width": "fill_container", "gap": 40, "padding": [10, 0, 0, 0], "children": [{"type": "frame", "id": "MkWnn", "name": "THE MAKER", "width": "fill_container", "stroke": "$ink-2", "strokeWidth": {"top": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 8, "padding": [12, 0, 0, 0], "children": [{"type": "text", "id": "a0BRE", "name": "h", "fill": "$terra-lite", "content": "THE MAKER", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1.4}, {"type": "text", "id": "vHzpD", "name": "t", "fill": "$muted-on-ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Goods. designs, presses, builds, sells and delivers. A bed costs $750 and the money that comes back makes the next bed.", "lineHeight": 1.55, "fontFamily": "$font-body", "fontSize": 12.5, "fontWeight": "normal"}]}, {"type": "frame", "id": "NBMXS", "name": "THE CHARITY", "width": "fill_container", "stroke": "$ink-2", "strokeWidth": {"top": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 8, "padding": [12, 0, 0, 0], "children": [{"type": "text", "id": "TwtIs", "name": "h", "fill": "$terra-lite", "content": "THE CHARITY", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1.4}, {"type": "text", "id": "QqG5H", "name": "t", "fill": "$muted-on-ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Goods on Country pays the yearly bill while the maker grows. It is the steward of the handover.", "lineHeight": 1.55, "fontFamily": "$font-body", "fontSize": 12.5, "fontWeight": "normal"}]}, {"type": "frame", "id": "BZLwK", "name": "THE LOAN ARM", "width": "fill_container", "stroke": "$ink-2", "strokeWidth": {"top": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 8, "padding": [12, 0, 0, 0], "children": [{"type": "text", "id": "m0myW", "name": "h", "fill": "$terra-lite", "content": "THE LOAN ARM", "fontFamily": "$font-mono", "fontSize": 10, "fontWeight": "normal", "letterSpacing": 1.4}, {"type": "text", "id": "NV7nl", "name": "t", "fill": "$muted-on-ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "A Curious Tractor holds repayable money: loans that bridge big orders and go home again.", "lineHeight": 1.55, "fontFamily": "$font-body", "fontSize": 12.5, "fontWeight": "normal"}]}]}, {"type": "text", "id": "I31zD", "name": "Foot", "fill": "$cream", "textGrowth": "fixed-width", "width": 900, "content": "Give to Goods on Country. Buy from Goods. Lend through A Curious Tractor. All three roads end at the same place: a plant in community hands.", "lineHeight": 1.5, "fontFamily": "$font-body", "fontSize": 13.5, "fontWeight": "normal", "fontStyle": "italic"}]}, {"type": "text", "id": "H1qcN", "name": "Folio", "fill": "$muted-on-ink", "content": "APPENDIX A  ·  NOT IN THE TWELVE  ·  REACH FOR IT WHEN ASKED", "fontFamily": "$font-mono", "fontSize": 9, "fontWeight": "normal", "letterSpacing": 1.6}]}, {"type": "frame", "id": "SkHpr", "x": 0, "y": 3360, "name": "MAP 1 — Where the beds are (deployed)", "clip": true, "width": 1280, "height": 720, "fill": {"type": "image", "enabled": true, "url": "deck-photos/maps/map-deployed-r2.png", "mode": "fill"}, "layout": "none", "children": [{"type": "text", "id": "nnObA", "x": 44, "y": 690, "name": "Source", "fill": "$muted", "content": "LIVE RENDER · /export/map/deployed · re-export to refresh", "fontFamily": "$font-mono", "fontSize": 8, "fontWeight": "normal", "letterSpacing": 1.2}]}, {"type": "frame", "id": "lIhTp", "x": 1400, "y": 3360, "name": "MAP 2 — Who has asked for their own plant", "clip": true, "width": 1280, "height": 720, "fill": {"type": "image", "enabled": true, "url": "deck-photos/maps/map-ask-r3.png", "mode": "fill"}, "layout": "none", "children": [{"type": "text", "id": "JAvHW", "x": 44, "y": 690, "name": "Source", "fill": "$muted", "content": "LIVE RENDER · /export/map/ask · 5 have asked · re-export to a NEW filename to refresh (Pencil caches by path)", "fontFamily": "$font-mono", "fontSize": 8, "fontWeight": "normal", "letterSpacing": 1.2}]}, {"type": "frame", "id": "yYcJj", "x": 2800, "y": 3360, "name": "MAP 3 — Need overlay (Modelled)", "clip": true, "width": 1280, "height": 720, "fill": {"type": "image", "enabled": true, "url": "deck-photos/maps/map-need-r2.png", "mode": "fill"}, "layout": "none", "children": [{"type": "text", "id": "RWcsn", "x": 44, "y": 690, "name": "Source", "fill": "$muted", "content": "LIVE RENDER · /export/map/need · re-export to refresh", "fontFamily": "$font-mono", "fontSize": 8, "fontWeight": "normal", "letterSpacing": 1.2}]}]}