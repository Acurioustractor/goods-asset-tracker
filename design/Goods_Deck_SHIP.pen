"fontFamily": "$font-body", "fontSize": 14, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "m1fp9", "name": "Attrib", "fill": "$muted-on-ink", "content": "IVY · PALM ISLAND", "fontFamily": "$font-mono", "fontSize": 9.5, "fontWeight": "normal", "letterSpacing": 1.2}]}]}, {"type": "text", "id": "yR60M", "x": 56, "y": 658, "name": "Folio", "fill": "$muted-on-ink", "content": "02", "fontFamily": "$font-mono", "fontSize": 9.5, "fontWeight": "normal", "letterSpacing": 1.8}]}, {"type": "frame", "id": "h9oIr", "x": 2800, "y": 0, "name": "FINAL2 03 — So we asked", "clip": true, "width": 1280, "height": 720, "children": [{"type": "frame", "id": "t42b8m", "name": "Photo", "width": 768, "height": 720, "fill": {"type": "image", "enabled": true, "url": "../v2/public/images/media-pack/nic-with-elder-on-verandah.jpg", "mode": "fill"}}, {"type": "frame", "id": "wEHqs", "name": "Ink panel", "width": 512, "height": 720, "fill": "$ink", "layout": "vertical", "padding": 44, "children": [{"type": "frame", "id": "tOtmg", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-white.png", "mode": "fit"}}, {"type": "frame", "id": "nXTJY", "name": "Body", "width": "fill_container", "height": "fill_container", "layout": "vertical", "gap": 14, "justifyContent": "center", "children": [{"type": "rectangle", "id": "wUb2B", "name": "Rule", "fill": "$terra", "width": 34, "height": 2}, {"type": "text", "id": "a8Vkh", "name": "Line", "fill": "$cream", "textGrowth": "fixed-width", "width": "fill_container", "content": "So we asked. Then built it together.", "lineHeight": 1.28, "fontFamily": "$font-display", "fontSize": 25, "fontWeight": "normal"}, {"type": "text", "id": "sWFyk", "name": "Sub", "fill": "$muted-on-ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "Sixty years of furniture designed somewhere else, dying in months.", "lineHeight": 1.55, "fontFamily": "$font-body", "fontSize": 11.5, "fontWeight": "normal"}, {"type": "frame", "id": "W6F6u", "name": "Voice", "width": "fill_container", "stroke": "$terra", "strokeWidth": {"left": 1}, "strokeAlignment": "inner", "layout": "vertical", "gap": 5, "padding": [10, 0, 0, 12], "children": [{"type": "text", "id": "eiYVr", "name": "Quote", "fill": "#D8D2C7", "textGrowth": "fixed-width", "width": "fill_container", "content": "We've never been asked what sort of house we'd like to live in.", "lineHeight": 1.5, "fontFamily": "$font-body", "fontSize": 11.5, "fontWeight": "normal", "fontStyle": "italic"}, {"type": "text", "id": "OAXK5", "name": "Attrib", "fill": "$muted-on-ink", "content": "LINDA TURNER · TENNANT CREEK", "fontFamily": "$font-mono", "fontSize": 9, "fontWeight": "normal", "letterSpacing": 1.1}]}]}, {"type": "frame", "id": "Eqm4D", "name": "Foot", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "L6rVoD", "name": "Folio", "fill": "$muted-on-ink", "content": "03", "fontFamily": "$font-mono", "fontSize": 9, "fontWeight": "normal", "letterSpacing": 1.6}, {"type": "text", "id": "T7LaSG", "name": "Door", "fill": "$ink-2", "fontFamily": "$font-mono", "fontSize": 9, "fontWeight": "normal", "letterSpacing": 1}]}]}]}, {"type": "frame", "id": "PULXe", "x": 4200, "y": 0, "name": "FINAL2 04 — 540 beds, 22 washers, 11 communities", "clip": true, "width": 1280, "height": 720, "fill": "$cream", "layout": "vertical", "gap": 22, "padding": [56, 72], "children": [{"type": "frame", "id": "N40Io", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-black.png", "mode": "fit"}}, {"type": "frame", "id": "r9DxLu", "name": "Head", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "DECtv", "name": "Folio", "fill": "$terra", "content": "04", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 2}, {"type": "text", "id": "WkaJT", "name": "Door", "fill": "$terra", "content": "see it live → goodsoncountry.com/atlas", "fontFamily": "$font-mono", "fontSize": "$size-kicker", "fontWeight": "normal", "letterSpacing": 1.4}]}, {"type": "rectangle", "id": "opvZR", "name": "Rule", "fill": "$terra", "width": "fill_container", "height": 2}, {"type": "text", "id": "GRhMG", "name": "Line", "fill": "$ink", "textGrowth": "fixed-width", "width": "fill_container", "content": "540 beds. 22 washing machines. 11 communities.", "lineHeight": 1.1, "fontFamily": "$font-display", "fontSize": 44, "fontWeight": "normal"}, {"type": "text", "id": "wAckz", "name": "Sub", "fill": "$ink-2", "textGrowth": "fixed-width", "width": "fill_container", "content": "Every one on the register, with a name beside it.", "fontFamily": "$font-body", "fontSize": 16, "fontWeight": "normal"}, {"type": "frame", "id": "fRET5", "name": "Split bar", "width": "fill_container", "height": 52, "gap": 4, "children": [{"type": "rectangle", "cornerRadius": [3, 0, 0, 3], "id": "vDXmj", "name": "Stretch 177", "fill": "$terra", "width": 371, "height": 52}, {"type": "rectangle", "cornerRadius": [0, 3, 3, 0], "id": "emGyt", "name": "Basket 363", "fill": "$sage", "width": 761, "height": 52}]}, {"type": "frame", "id": "MIw5G", "name": "Bar labels", "width": "fill_container", "gap": 4, "children": [{"type": "frame", "id": "h1avR", "name": "177", "width": 371, "layout": "vertical", "gap": 2, "children": [{"type": "text", "id": "KqIpL", "name": "n", "fill": "$terra", "content": "177", "fontFamily": "$font-display", "fontSize": 22, "fontWeight": "normal"}, {"type": "text", "id": "jlFLS", "name": "s", "fill": "$muted", "content": "STRETCH BEDS", "fontFamily": "$font-mono", "fontSize": 11, "fontWeight": "normal", "letterSpacing": 1}]}, {"type": "frame", "id": "YJYVM", "name": "363", "width": 761, "layout": "vertical", "gap": 2, "children": [{"type": "text", "id": "ivZD2", "name": "n", "fill": "$sage", "