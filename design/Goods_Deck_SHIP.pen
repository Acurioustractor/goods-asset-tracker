"space-1": {"type": "number", "value": 4}, "space-2": {"type": "number", "value": 8}, "space-3": {"type": "number", "value": 12}, "space-4": {"type": "number", "value": 16}, "space-6": {"type": "number", "value": 24}, "space-8": {"type": "number", "value": 32}, "space-10": {"type": "number", "value": 40}, "radius-input": {"type": "number", "value": 2}, "border-hairline": {"type": "number", "value": 1}, "border-emphasis": {"type": "number", "value": 2}}, "children": [{"type": "frame", "id": "yvevN", "x": 0, "y": 0, "name": "FINAL2 01 — A split — The goal was never a bigger Goods", "clip": true, "width": 1280, "height": 720, "children": [{"type": "frame", "id": "D4Yhgn", "name": "Ink panel", "width": 512, "height": 720, "fill": "$ink", "layout": "vertical", "padding": 44, "children": [{"type": "frame", "id": "t2kzIE", "name": "Wordmark", "width": 92, "height": 23, "fill": {"type": "image", "enabled": true, "url": "deck-photos/logo-goods-white.png", "mode": "fit"}}, {"type": "frame", "id": "KeE4h", "name": "Body", "width": "fill_container", "height": "fill_container", "layout": "vertical", "gap": 16, "justifyContent": "center", "children": [{"type": "rectangle", "id": "vDJ02", "name": "Rule", "fill": "$terra", "width": 34, "height": 2}, {"type": "text", "id": "Ru3AO", "name": "Line", "fill": "$cream", "textGrowth": "fixed-width", "width": "fill_container", "content": "The goal was never a bigger Goods. It is a plant that belongs to the people sleeping on the beds.", "lineHeight": 1.26, "fontFamily": "$font-display", "fontSize": 27, "fontWeight": "normal"}]}, {"type": "frame", "id": "r0E2B", "name": "Foot", "width": "fill_container", "justifyContent": "space_between", "alignItems": "center", "children": [{"type": "text", "id": "QID0s", "name": "Folio", "fill": "$muted-on-ink", "content": "01", "fontFamily": "$font-mono", "fontSize": 9, "fontWeight": "normal", "letterSpacing": 1.6}]}]}, {"type": "frame", "id": "c2Z6tI", "name": "Photo", "width": 768, "height": 720, "fill