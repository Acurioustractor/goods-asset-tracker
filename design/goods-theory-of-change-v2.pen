                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Families sleep on the floor or share too few beds. Overcrowding is the norm, not the exception.",
                      "lineHeight": 1.45,
                      "fontFamily": "$body",
                      "fontSize": 23,
                      "fontWeight": "normal"
                    }
                  ]
