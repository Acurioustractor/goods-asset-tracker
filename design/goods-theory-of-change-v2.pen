                      "name": "Text",
                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Sleeping on the ground drives scabies, then sores, then Strep A and rheumatic heart disease. Rates you find almost nowhere else on earth.",
                      "lineHeight": 1.45,
                      "fontFamily": "$body",
                      "fontSize": 23,
                      "fontWeight": "normal"
                    }
                  ]
